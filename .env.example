# ── Backend Go ──────────────────────────────────────────────────────────────
PORT=8080
GIN_MODE=debug   # debug | release

# ── PostgreSQL + PostGIS ─────────────────────────────────────────────────────
POSTGRES_HOST=postgres    # nom du service Docker (localhost si hors Docker)
POSTGRES_PORT=5432
POSTGRES_DB=homepedia
POSTGRES_USER=homepedia
POSTGRES_PASSWORD=homepedia

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/homepedia

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis          # nom du service Docker (localhost si hors Docker)
REDIS_PORT=6379

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# IMPORTANT : port INTERNE Docker = 8000 (backend → chromadb en réseau Docker)
# Port hôte exposé = 8001 (accès depuis la machine hôte uniquement)
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production

# ── Azure Data Lake Gen2 (ingestion Python uniquement) ───────────────────────
# Ces variables sont dans ingestion/.env — NE PAS les committer
# ADLS_ACCOUNT_NAME=homepediadatalake
# ADLS_ACCOUNT_KEY=...
